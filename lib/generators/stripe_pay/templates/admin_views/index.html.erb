<div class="container-xl py-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">Payments</h1>
  </div>

  <!-- Filters -->
  <div class="card mb-6">
    <div class="card-body">
      <%%= form_with url: admin_payments_path, method: :get, class: "flex gap-4 flex-wrap" do |f| %>
        <div class="flex-1 min-w-[200px]">
          <%%= f.text_field :q, value: params[:q], placeholder: "Search by ID or email", class: "form-input w-full" %>
        </div>
        <div>
          <%%= f.select :status,
              options_for_select([['All', ''], ['Pending', 'pending'], ['Processing', 'processing'], ['Paid', 'paid'], ['Failed', 'failed'], ['Canceled', 'canceled'], ['Refunded', 'refunded']], params[:status]),
              {}, class: "form-select" %>
        </div>
        <div>
          <%%= f.submit "Filter", class: "btn-primary" %>
        </div>
      <%% end %>
    </div>
  </div>

  <!-- Payments Table -->
  <div class="card">
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Payable</th>
<% if @auth -%>
            <th>User</th>
<% end -%>
            <th>Amount</th>
            <th>Status</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <%% @payments.each do |payment| %>
            <tr>
              <td>
                <span class="font-mono text-sm">#<%%= payment.id %></span>
              </td>
              <td>
                <div class="text-sm">
                  <div class="font-medium"><%%= payment.payable_type %> #<%%= payment.payable_id %></div>
                  <div class="text-muted"><%%= payment.product_description %></div>
                </div>
              </td>
<% if @auth -%>
              <td>
                <%% if payment.user %>
                  <div class="text-sm"><%%= payment.user.email %></div>
                <%% else %>
                  <span class="text-muted">Guest</span>
                <%% end %>
              </td>
<% end -%>
              <td class="font-medium">
                <%%= number_to_currency(payment.amount, unit: payment.currency.upcase + ' ') %>
              </td>
              <td>
                <span class="badge-<%%= case payment.status
                      when 'paid' then 'success'
                      when 'failed' then 'danger'
                      when 'pending' then 'warning'
                      when 'processing' then 'info'
                      else 'neutral'
                      end %>">
                  <%%= payment.display_status %>
                </span>
              </td>
              <td class="text-sm text-muted">
                <%%= payment.created_at.strftime('%Y-%m-%d %H:%M') %>
              </td>
              <td>
                <%%= link_to "View", [:admin, payment], class: "btn-sm btn-outline" %>
              </td>
            </tr>
          <%% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pagination -->
  <%% if @payments.respond_to?(:current_page) %>
    <div class="flex justify-center mt-6">
      <%%= paginate @payments %>
    </div>
  <%% end %>
</div>
