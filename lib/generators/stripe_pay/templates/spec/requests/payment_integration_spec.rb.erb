require 'rails_helper'

RSpec.describe "Payment Integration", type: :request do
  describe "CLACKY_TODO validation" do
    it "validates that all payment CLACKY_TODOs have been resolved" do
      check_clacky_todos([
        'app/controllers/payments_controller.rb',
        'app/controllers/admin/payments_controller.rb',
        'app/services/stripe_payment_service.rb'
      ])
    end

    it "validates that required payment views have been created" do
      missing_views = []

      required_views = [
        'app/views/payments/show.html.erb',
        'app/views/payments/success.html.erb'
      ]

      required_views.each do |view_path|
        unless File.exist?(Rails.root.join(view_path))
          missing_views << view_path
        end
      end

      if missing_views.any?
        error_message = "\n❌ Missing required payment views:\n\n"
        missing_views.each do |view|
          error_message += "📄 #{view}\n"
        end
        error_message += "\nThese views are required for the payment flow to work.\n"
        error_message += "Check the CLACKY_TODO comments in PaymentsController for guidance.\n"

        fail error_message
      end
    end

    it "validates that payment views use pay_button partial correctly" do
      violations = []

      # Check all views for direct button_to pay_payment_path usage
      Dir.glob(Rails.root.join('app/views/**/*.html.erb')).each do |file_path|
        content = File.read(file_path)
        relative_path = file_path.sub(Rails.root.to_s + '/', '')

        # Skip the pay_button partial itself
        next if relative_path.include?('_pay_button.html.erb')
        next if relative_path.include?('payments/pay.turbo_stream.erb')

        # Check for direct button_to pay_payment_path instead of using partial
        if content.match?(/button_to.*pay_payment_path/) && !content.match?(/render.*payments\/pay_button/)
          violations << {
            file: relative_path,
            issue: "Direct button_to pay_payment_path instead of using pay_button partial"
          }
        end

        # Check for passing wrong object to pay_payment_path (should be payment, not order/subscription)
        if content.match?(/pay_payment_path\s*\(\s*[^@]/) ||
           content.match?(/pay_payment_path\s*\(\s*@(?!payment\b)/)
          violations << {
            file: relative_path,
            issue: "pay_payment_path should receive @payment, not @order/@subscription/other objects"
          }
        end
      end

      if violations.any?
        error_message = "\n❌ Found #{violations.length} payment button violation(s):\n\n"

        violations.each do |v|
          error_message += "📄 #{v[:file]}\n"
          error_message += "   Issue: #{v[:issue]}\n"
          error_message += "   Fix: Use <%%= render 'payments/pay_button', payment: @payment %>\n\n"
        end

        error_message += "Correct pattern:\n"
        error_message += "  Use the pay_button partial for consistent payment UI and test card hints.\n"

        fail error_message
      end
    end
  end
end
