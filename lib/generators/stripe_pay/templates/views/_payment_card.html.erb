<%%
  # Payment card component
  # Usage: render 'payments/payment_card', payment: @payment, show_payable: true
  #
  # CLACKY_NOTE: This is a BASIC card component showing minimal payment info.
  # Customize based on your business:
  # - Add payable-specific details (order items, subscription plan, etc.)
  # - Customize action buttons based on payment status
  # - Adjust styling to match your design system
%>

<% show_payable ||= false %>

<div class="card" id="payment_<%%= payment.id %>">
  <div class="card-body">
    <div class="flex justify-between items-start">
      <div class="flex-1">
        <h3 class="text-lg font-semibold">Payment #<%%= payment.id %></h3>
        <p class="text-sm text-secondary mt-1">
          <%%= payment.product_description %>
        </p>
        <div class="mt-2">
          <span class="text-lg font-bold text-primary">
            <%%= number_to_currency(payment.amount, unit: payment.currency.upcase + ' ') %>
          </span>
          <span class="ml-2">
            <%%= render 'payments/status_badge', payment: payment %>
          </span>
        </div>

        <%% if show_payable && payment.payable %>
          <div class="mt-4 pt-4 border-t border-base-300">
            <p class="text-sm text-secondary"><%%= payment.payable_type %> #<%%= payment.payable_id %></p>
            <%% # CLACKY_TODO: Render payable-specific details
                # Example: render payment.payable if payment.payable %>
          </div>
        <%% end %>
      </div>

      <div class="ml-6 space-y-2">
        <%%= link_to "View", payment_path(payment), class: "btn-sm btn-outline" %>

        <%% # CLACKY_TODO: Customize actions based on status and business logic %>
        <%% if payment.pending? || payment.failed? %>
          <%%= render 'payments/pay_button', payment: payment, text: 'Pay', css_class: 'btn-sm btn-primary' %>
        <%% end %>
      </div>
    </div>
  </div>
</div>
