<%% # Stripe payment button
   # CRITICAL: DO NOT modify - handles Stripe payment correctly
   #
   # Payment flow:
   # - Button submits POST request to pay_payment_path
   # - Controller returns turbo_stream response with redirect to Stripe
   # - After payment, Stripe redirects back to success/failure URL
   #
   # Usage:
   #   render 'payments/pay_button', payment: @payment
   #   render 'payments/pay_button', payment: @payment, text: 'Buy Now', css_class: 'btn-lg'
-%>

<%% if Rails.env.development? && (payment.pending? || payment.failed? || payment.processing?) %>
<div class="alert-info mb-6">
  <div class="flex">
    <div class="flex-shrink-0">
      <svg class="h-5 w-5 text-info mr-3" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
      </svg>
    </div>
    <div class="ml-3">
      <h3 class="text-sm font-medium">Test Payment (Development Mode)</h3>
      <div class="mt-2 text-sm">
        <p class="mb-2">Use these test cards (no real charges):</p>
        <ul class="list-disc list-inside space-y-1">
          <li><strong>Success:</strong> 4242 4242 4242 4242</li>
          <li><strong>Decline:</strong> 4000 0000 0000 0002</li>
        </ul>
        <p class="mt-2"><strong>Expiry:</strong> Any future date | <strong>CVC:</strong> Any 3 digits</p>
      </div>
    </div>
  </div>
</div>
<%% end %>

<%% if payment.pending? || payment.failed? || payment.processing? %>
  <%% text ||= payment.failed? ? "Retry Payment" : "Pay Now" -%>
  <%% css_class ||= "btn-primary" -%>

  <%%= button_to text,
      pay_payment_path(payment),
      method: :post,
      class: css_class,
      data: { turbo_submits_with: "Processing..." } %>
<%% elsif payment.paid? %>
  <span class="badge-success">Payment Completed</span>
<%% end %>
