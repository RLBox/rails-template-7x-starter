<!-- Dashboard Navbar - Feature-rich design for application interfaces -->
<!-- DO NOT modify data-controller, data-action, or data-dropdown-target attributes -->

<nav class="bg-surface-elevated border-b border-border"
     data-controller="dropdown"
     data-dropdown-close-on-click-outside-value="false">
  <div class="container-xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">

      <!-- Left section: Logo + Navigation -->
      <div class="flex items-center space-x-8">
        <!-- CLACKY_TODO: Customize your logo, Use Rails.application.config.x.appname for appname -->

        <!-- Desktop navigation -->
        <div class="hidden lg:flex items-center space-x-1">
          <%= render 'shared/nav_links' %>
        </div>
      </div>

      <!-- Right section: User menu -->
      <div class="hidden md:flex items-center space-x-4">
        <% if current_user %>
          <%= render 'shared/user_dropdown' %>
        <% else %>
          <%= link_to "Sign In", sign_in_path, class: "btn-ghost btn-sm" %>
          <%= link_to "Sign Up", sign_up_path, class: "btn-primary btn-sm" %>
        <% end %>
      </div>

      <!-- Mobile hamburger - DO NOT REMOVE -->
      <button type="button"
              data-action="click->dropdown#toggle"
              class="md:hidden p-2 text-secondary hover:bg-surface rounded-lg transition-colors">
        <%= lucide_icon "menu", class: "w-6 h-6" %>
      </button>
    </div>

    <!-- Mobile drawer - DO NOT REMOVE this structure -->
    <div data-dropdown-target="menu" class="hidden fixed inset-0 z-50 md:hidden">
      <!-- Background overlay -->
      <div class="fixed inset-0 bg-black/50" data-action="click->dropdown#close"></div>

      <!-- Drawer content -->
      <div class="fixed right-0 top-0 h-full w-64 bg-surface-elevated shadow-xl overflow-y-auto">
        <div class="p-4">
          <!-- Close button -->
          <button type="button"
                  data-action="click->dropdown#close"
                  class="mb-6 p-2 hover:bg-surface rounded-lg transition-colors">
            <%= lucide_icon "x", class: "w-6 h-6" %>
          </button>

          <!-- Mobile navigation -->
          <div class="mb-6 space-y-1">
            <%= render 'shared/nav_links' %>
          </div>

          <!-- Mobile user menu -->
          <div class="border-t border-border pt-4">
            <% if current_user %>
              <%= render 'shared/user_dropdown' %>
            <% else %>
              <div class="flex flex-col space-y-2">
                <%= link_to "Sign In", sign_in_path, class: "btn-ghost btn-md w-full" %>
                <%= link_to "Sign Up", sign_up_path, class: "btn-primary btn-md w-full" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
