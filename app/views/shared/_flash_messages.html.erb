<% flash.each do |key, value| %>
  <%
    toast_type = case key.to_sym
                 when :notice, :success then 'success'
                 when :alert, :error, :danger then 'error'
                 when :warning then 'warning'
                 else 'info'
                 end
  %>
  <!-- stimulus-validator: allow-script -->
  <script>window.showToast(<%= raw value.to_json %>, '<%= toast_type %>');</script>
<% end %>
