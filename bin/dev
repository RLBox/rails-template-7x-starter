#!/usr/bin/env sh

# Clean up stale server PID
if [ -f tmp/pids/server.pid ]; then
  pid=$(cat tmp/pids/server.pid)
  if kill -0 "$pid" 2>/dev/null; then
    echo "Stopping existing server (PID: $pid)..."
    kill "$pid" && sleep 1
  fi
  rm -f tmp/pids/server.pid
fi

if gem list --no-installed --exact --silent foreman; then
  echo "Installing foreman..."
  gem install foreman
fi

# Read APP_PORT from config/application.yml (figaro managed)
# Supports: APP_PORT: '3001' or "3001" or 3001
if [ -f config/application.yml ]; then
  APP_PORT_VALUE=$(grep "^APP_PORT:" config/application.yml | sed "s/^APP_PORT:[[:space:]]*//; s/['\"]//g" | xargs)
  if [ -n "$APP_PORT_VALUE" ]; then
    export APP_PORT="$APP_PORT_VALUE"
    echo "Using APP_PORT=$APP_PORT from config/application.yml"
  fi
fi

# Set PORT for foreman (fallback to APP_PORT, then default 3000)
export PORT="${PORT:-${APP_PORT:-3000}}"

exec foreman start -f Procfile.dev "$@"
